{
  "manifest_version": 3,
  "name": "ADHD Focus Reader",
  "version": "0.1.0",
  "description": "Improve readability by emphasizing the first part of words in article-like text.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "ADHD Focus Reader",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
